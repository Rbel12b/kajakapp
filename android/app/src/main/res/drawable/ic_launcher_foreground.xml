<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground · variant A "Paddler"
     108dp render, 512x512 viewport. Content is wrapped in a 0.66x group
     so the kayaker fits inside the launcher's safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <group
        android:pivotX="256"
        android:pivotY="256"
        android:scaleX="0.66"
        android:scaleY="0.66">

        <!-- water arc (translucent dark cyan) -->
        <path
            android:fillColor="#0E7490"
            android:fillAlpha="0.35"
            android:pathData="M32,390 Q256,350 480,390 L480,420 Q256,380 32,420 Z"/>

        <!-- kayak hull -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M60,358 C160,408 352,408 452,358 C352,388 160,388 60,358 Z"/>

        <!-- cockpit shadow (ellipse) -->
        <path
            android:fillColor="#0E7490"
            android:fillAlpha="0.35"
            android:pathData="M194,368 a62,10 0 1,0 124,0 a62,10 0 1,0 -124,0 Z"/>

        <!-- paddle (rotated -22°) -->
        <group
            android:pivotX="256"
            android:pivotY="268"
            android:rotation="-22">

            <!-- left blade · rect(68,252,60,32) r=14 -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M82,252 H114 a14,14 0 0 1 14,14 V270 a14,14 0 0 1 -14,14 H82 a14,14 0 0 1 -14,-14 V266 a14,14 0 0 1 14,-14 Z"/>

            <!-- right blade · rect(384,252,60,32) r=14 -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M398,252 H430 a14,14 0 0 1 14,14 V270 a14,14 0 0 1 -14,14 H398 a14,14 0 0 1 -14,-14 V266 a14,14 0 0 1 14,-14 Z"/>

            <!-- shaft · rect(110,260,292,16) r=8 (pill) -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M118,260 H394 a8,8 0 0 1 8,8 a8,8 0 0 1 -8,8 H118 a8,8 0 0 1 -8,-8 a8,8 0 0 1 8,-8 Z"/>
        </group>

        <!-- torso -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M218,360 Q218,270 256,250 Q294,270 294,360 Z"/>

        <!-- head -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M216,208 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0 Z"/>
    </group>
</vector>
